{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": ["config:best-practices"],
    "packageRules": [
        {
            "matchUpdateTypes": ["minor", "patch"],
            "matchCurrentVersion": "!/^0/",
            "automerge": true
        }
    ],
    "rangeStrategy": "bump",
    "minimumReleaseAge": "7 days",
    "lockFileMaintenance": {
        "enabled": true
    }
}
